# Operator-specific configuration for scripts/deploy-mcp.sh.
#
# Copy to .env (gitignored) and fill in your values. The deploy script
# sources this file before running; nothing in tracked source assumes any
# particular GCP project, region, service name, or bucket prefix.

# GCP project that owns the Cloud Run service, Artifact Registry repo,
# GCS session bucket, and service account.
PATHFINDER_GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run region. The Artifact Registry repo lives in the same region.
PATHFINDER_GCP_REGION=us-central1

# Artifact Registry repository name (created on first deploy if absent).
PATHFINDER_GCP_AR_REPO=pathfinder

# Cloud Run service name.
PATHFINDER_GCP_SERVICE_NAME=pathfinder-mcp

# Prefix for the session bucket + dedicated service account id. The deploy
# script appends `-<env>` (default `-dev`) to form the final bucket name
# (`<prefix>-dev`) and SA id (`<prefix>-dev`). Keep this short and unique
# to your project — GCS bucket names are globally unique across all of GCS.
PATHFINDER_GCP_RESOURCE_PREFIX=your-resource-prefix

# Optional: environment scope name (default: dev). Used in bucket + SA
# names so dev / staging / prod can co-exist.
# PATHFINDER_DEPLOY_ENV=dev
